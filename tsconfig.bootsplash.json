{
    "compilerOptions": {
        "target": "ES2020",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "types": [
            "node"
        ],
        "esModuleInterop": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "noEmit": true
    },
    "ts-node": {
        "transpileOnly": true
    },
    "include": [
        "src/configs/bootsplash/**/*.ts"
    ]
}